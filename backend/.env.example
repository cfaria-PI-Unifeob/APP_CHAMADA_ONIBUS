# Copie para .env local (não commite segredos).
PORT=3000

# Neon: Dashboard → Connection string → copie (inclui sslmode=require).
DATABASE_URL=

# Origens permitidas no CORS (separadas por vírgula). Ex.: https://seu-app.onrender.com,https://seu-dominio.com
# No Render, use a URL pública do seu front (Flutter web estático ou outro host).
CORS_ORIGIN=

# Groq — chat /api/ia/chat (https://console.groq.com)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Login JWT (obrigatório em produção no Render)
JWT_SECRET=
